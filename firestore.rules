rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAdmin() {
      return request.auth != null && (request.auth.token.role == 'admin' || request.auth.token.admin == true);
    }

    match /evaluationResults/{document=**} {
      allow read: if true;
      allow write: if false;
    }

    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
      allow read: if isAdmin();
    }

    match /usernames/{username} {
      allow read: if false;
      allow create: if request.auth != null && request.resource.data.uid == request.auth.uid;
      allow update, delete: if false;
    }

    match /citizenReports/{reportId} {
      allow read, write: if isAdmin();
      allow create: if request.auth != null;
      allow read: if request.auth != null && (resource.data.userId == request.auth.uid || resource.data.userEmail == request.auth.token.email);
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
